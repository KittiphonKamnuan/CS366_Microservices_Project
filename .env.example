# Copy to .env and fill in values

# PostgreSQL — RDS endpoint
DATABASE_URL=postgresql://volunteer_user:yourpassword@<rds-endpoint>:5432/volunteer_db

# Server
HOST=0.0.0.0
PORT=8080

# AWS SNS topic ARNs (leave empty to use mock/log mode)
SNS_LOCATION_TOPIC_ARN=arn:aws:sns:us-east-1:<account-id>:volunteer-location-updated
SNS_MATCH_TOPIC_ARN=arn:aws:sns:us-east-1:<account-id>:match-status-changed

# Rust log level
RUST_LOG=info
